%% ===== Grand Challenge Signal Processing Combined Script =====
% This script combines:
% 1) Filtering all sensor data
% 2) Windowing / near-fall duration analysis
% 3) ML model building (Random Forest and SMV Cross Validation)

clear; clc;

%% 1) Load MAT file
filePath = "/Users/sophiakatramadakis/Documents/MATLAB/GrandChallengeData.mat"; % <-- update if needed
S = load(filePath);

disp("Top-level variables in MAT file:");
disp(fieldnames(S))

%% 2) Assign labels
if ~isfield(S, "clean_labels")
    error("Expected S.clean_labels but it wasn't found. Check fieldnames(S).");
end
labels = S.clean_labels;

%% 3) Auto-find raw sensor struct
names = fieldnames(S);
raw = [];

for k = 1:numel(names)
    nm = names{k};

    if strcmp(nm, "clean_labels")
        continue;
    end
    if ~isstruct(S.(nm))
        continue;
    end
    if ~isfield(S.(nm), "P1960")
        continue;
    end

    trialFields = fieldnames(S.(nm).P1960);
    if isempty(trialFields)
        continue;
    end

    t1 = trialFields{1};
    if isstruct(S.(nm).P1960.(t1))
        sf = fieldnames(S.(nm).P1960.(t1));
        if any(strcmp(sf,"Back")) && any(strcmp(sf,"ECG")) && any(strcmp(sf,"GSS"))
            raw = S.(nm);
            fprintf("Using RAW sensor struct: S.%s\n", nm);
            break
        end
    end
end

if isempty(raw)
    error("Could not auto-find the raw sensor struct. Paste fieldnames(S) and I’ll point to it.");
end

%% ============================================================
%% SECTION A - FILTERING
%% ============================================================

%% Filter parameters
IMU.lowpass_fc = 20;      % Hz

ECG.bandpass_f1 = 0.5;    % Hz
ECG.bandpass_f2 = 150;    % Hz
ECG.use_notch   = true;
ECG.notch_f1    = 50;     % Hz
ECG.notch_f2    = 70;     % Hz

GSR.lowpass_fc = 1;       % Hz

%% Apply filters to ALL data
raw_filt = raw;

participants_raw = string(fieldnames(raw));

for p = 1:numel(participants_raw)
    pID = participants_raw(p);
    trialNames = string(fieldnames(raw.(pID)));

    for tt = 1:numel(trialNames)
        tr = trialNames(tt);
        X = raw.(pID).(tr);

        if isfield(X,"Back")
            raw_filt.(pID).(tr).Back = filterIMU_Matrix(X.Back, IMU.lowpass_fc);
        end

        if isfield(X,"Left_Thigh")
            raw_filt.(pID).(tr).Left_Thigh = filterIMU_Matrix(X.Left_Thigh, IMU.lowpass_fc);
        end

        if isfield(X,"Right_Thigh")
            raw_filt.(pID).(tr).Right_Thigh = filterIMU_Matrix(X.Right_Thigh, IMU.lowpass_fc);
        end

        if isfield(X,"ECG")
            raw_filt.(pID).(tr).ECG = filterECG_Matrix(X.ECG, ECG.bandpass_f1, ECG.bandpass_f2, ...
                ECG.use_notch, ECG.notch_f1, ECG.notch_f2);
        end

        if isfield(X,"GSS")
            raw_filt.(pID).(tr).GSS = filterGSR_Matrix(X.GSS, GSR.lowpass_fc);
        end
    end
end

disp("Filtering complete: raw_filt created (same structure as raw).");

%% Plot RAW vs FILTERED for selected participants and trials
participantsToPlot = ["P1960","P2070","P2995"];

perturbTrial = "Slip";
adlTrial     = "Walk";
standTrial   = "Stand";

for pID = participantsToPlot
    fprintf("\n=== Plotting participant %s (RAW vs FILTERED) ===\n", pID);

    if ~isfield(labels, pID) || ~isfield(labels.(pID), perturbTrial)
        warning("No labels found for %s %s. Skipping perturb plots.", pID, perturbTrial);
    else
        T = labels.(pID).(perturbTrial);

        nf_rows = find(T(:,3)==1);
        if numel(nf_rows) >= 3
            nf_block = T(nf_rows(1:3),:);
            t_nf0 = nf_block(1,2)/1000;
            t_nf1 = nf_block(3,2)/1000 + 2;

            plotSensorsWindow_RawVsFilt(raw, raw_filt, labels, pID, perturbTrial, ...
                t_nf0, t_nf1, true, "NEAR-FALL window (Slip) RAW vs FILTERED");
        else
            warning("No near-fall block (group 1) found in %s %s.", pID, perturbTrial);
        end

        fall_rows = find(T(:,3)==4);
        if numel(fall_rows) >= 4
            fall_block = T(fall_rows(1:4),:);
            t_f0 = fall_block(1,2)/1000;
            t_f1 = fall_block(4,2)/1000 + 2;

            plotSensorsWindow_RawVsFilt(raw, raw_filt, labels, pID, perturbTrial, ...
                t_f0, t_f1, true, "FALL window (Slip) RAW vs FILTERED");
        else
            warning("No fall block (group 4) found in %s %s.", pID, perturbTrial);
        end
    end

    if isfield(raw, pID)
        plotSensorsWindow_RawVsFilt(raw, raw_filt, labels, pID, adlTrial, ...
            0, 20, false, "ADL window (Walk) first 20s RAW vs FILTERED");
    end

    if isfield(raw, pID)
        plotSensorsWindow_RawVsFilt(raw, raw_filt, labels, pID, standTrial, ...
            0, 60, false, "ADL window (Stand) first 60s RAW vs FILTERED");
    end
end

%% ============================================================
%% SHARED SETTINGS FOR SECTION B AND C
%% ============================================================

rng(1);

adlWindow_s = 1.0;
adlStep_s   = 1.0;
eventBuffer_s = 0.25;
numTrees = 200;
minSamplesPerSegment = 20;

%% ============================================================
%% BUILD SHARED EVENT STRUCT
%% ============================================================
% This is the same event definition used by BOTH Section B and Section C.

eventStruct = buildEventStruct(labels);
disp("Event intervals built.");

%% ============================================================
%% SECTION B - WINDOWING / NEAR-FALL DURATION ANALYSIS
%% ============================================================
% Consistency fix
% Only count near-falls that Section C could also use:
% 1) matching raw trial exists
% 2) Back sensor exists
% 3) enough samples in the event segment

participants_labels = fieldnames(labels);

durations = [];
isFallAfter = [];
durParticipant = strings(0,1);
durTrial = strings(0,1);

for p = 1:numel(participants_labels)

    pID = participants_labels{p};

    if ~isfield(raw_filt, pID)
        continue
    end

    labelTrials = fieldnames(labels.(pID));

    for t = 1:numel(labelTrials)

        trLabel = labelTrials{t};

        rawTrialField = resolveRawTrialField(raw_filt.(pID), trLabel);
        if strlength(rawTrialField) == 0
            continue
        end

        if ~isfield(raw_filt.(pID).(rawTrialField), 'Back')
            continue
        end

        M = raw_filt.(pID).(rawTrialField).Back;
        if size(M,1) < minSamplesPerSegment
            continue
        end

        timeRaw = M(:,1);
        nearFalls = eventStruct.(pID).(trLabel).NearFall;

        for i = 1:size(nearFalls,1)
            t0 = nearFalls(i,1);
            t1 = nearFalls(i,2);
            termLbl = nearFalls(i,3);

            idx = timeRaw >= t0 & timeRaw <= t1;
            if sum(idx) < minSamplesPerSegment
                continue
            end

            durations(end+1,1) = t1 - t0;
            isFallAfter(end+1,1) = (termLbl == 4);
            durParticipant(end+1,1) = string(pID);
            durTrial(end+1,1) = string(trLabel);
        end
    end
end

%% 1) Total number of near-fall periods
nTotal = numel(durations);
fprintf("\nTotal usable near-fall periods across all participants and trials: %d\n", nTotal);

if isempty(durations)
    error("No usable near-fall events found after raw trial matching and minSamplesPerSegment filtering.");
end

%% 2) Average and standard deviation
meanDur = mean(durations);
stdDur  = std(durations);

fprintf("Average duration: %.3f s\n", meanDur);
fprintf("Standard deviation: %.3f s\n", stdDur);

%% 3) Median and IQR
medianDur = median(durations);
Q1 = quantile(durations, 0.25);
Q3 = quantile(durations, 0.75);
IQR_val = Q3 - Q1;
IQR_matlab = iqr(durations);

fprintf("25th percentile (Q1): %.3f s and 75th percentile (Q3): %.3f s\n", Q1, Q3);
fprintf("Median duration: %.3f s\n", medianDur);
fprintf("Interquartile range (IQR): %.3f s\n", IQR_val);
fprintf("MATLAB iqr check: %.3f s\n", IQR_matlab);

%% 4) Compare near-falls prior to fall vs recovered near-falls
dur_fall = durations(isFallAfter == 1);
dur_rec  = durations(isFallAfter == 0);

if ~isempty(dur_fall)
    mean_fall = mean(dur_fall);
else
    mean_fall = NaN;
end

if ~isempty(dur_rec)
    mean_rec = mean(dur_rec);
else
    mean_rec = NaN;
end

fprintf("\nMean duration (Near-Fall BEFORE Fall): %.3f s\n", mean_fall);
fprintf("Mean duration (Recovered Near-Fall): %.3f s\n", mean_rec);

if ~isempty(dur_fall) && ~isempty(dur_rec) && numel(dur_fall) > 1 && numel(dur_rec) > 1
    [~, pValue] = ttest2(dur_fall, dur_rec);
    fprintf("Two-sample t-test p-value: %.5f\n", pValue);
else
    pValue = NaN;
    fprintf("Two-sample t-test p-value: NaN (not enough samples in one or both groups)\n");
end

%% 5) Participant results table
pList = strings(0,1);
recCounts = [];
fallCounts = [];

for p = 1:numel(participants_labels)

    pID = participants_labels{p};

    if ~isfield(raw_filt, pID)
        continue
    end

    labelTrials = fieldnames(labels.(pID));
    nRec_p = 0;
    nFall_p = 0;

    for t = 1:numel(labelTrials)

        trLabel = labelTrials{t};

        rawTrialField = resolveRawTrialField(raw_filt.(pID), trLabel);
        if strlength(rawTrialField) == 0
            continue
        end

        if ~isfield(raw_filt.(pID).(rawTrialField), 'Back')
            continue
        end

        M = raw_filt.(pID).(rawTrialField).Back;
        if size(M,1) < minSamplesPerSegment
            continue
        end

        timeRaw = M(:,1);
        nearFalls = eventStruct.(pID).(trLabel).NearFall;

        for i = 1:size(nearFalls,1)
            t0 = nearFalls(i,1);
            t1 = nearFalls(i,2);
            termLbl = nearFalls(i,3);

            idx = timeRaw >= t0 & timeRaw <= t1;
            if sum(idx) < minSamplesPerSegment
                continue
            end

            if termLbl == 4
                nFall_p = nFall_p + 1;
            elseif termLbl == 3
                nRec_p = nRec_p + 1;
            end
        end
    end

    pList(end+1,1) = string(pID);
    recCounts(end+1,1) = nRec_p;
    fallCounts(end+1,1) = nFall_p;
end

resultsTable = table(pList, recCounts, fallCounts, recCounts + fallCounts, ...
    'VariableNames', {'Participant', 'NearFall_Recovered', 'NearFall_Fell', 'Total'});

overallRow = table("OVERALL", sum(recCounts), sum(fallCounts), ...
    sum(recCounts) + sum(fallCounts), ...
    'VariableNames', {'Participant', 'NearFall_Recovered', 'NearFall_Fell', 'Total'});

resultsTable = [resultsTable; overallRow];

fprintf("\n=============================\n");
disp(resultsTable);
fprintf("=============================\n");

%% 6) Histogram - all near-fall durations
mean_val = mean(durations);
median_val = median(durations);
Q1_all = prctile(durations,25);
Q3_all = prctile(durations,75);

figure
histogram(durations,25,'FaceColor',[0.3 0.3 0.3],'EdgeColor','none')
hold on
xline(mean_val,'r','LineWidth',1,'DisplayName','Mean')
xline(median_val,'b','LineWidth',1,'DisplayName','Median')
xline(Q1_all,'k--','LineWidth',1,'DisplayName','Q1')
xline(Q3_all,'k--','LineWidth',1,'DisplayName','Q3')
xlabel('Near-fall Duration (s)')
ylabel('Number of Events')
title('Distribution of Usable Near-Fall Durations')
legend('Near-fall durations','Mean','Median','Q1','Q3')
grid on
hold off

%% 7) Histogram - recovered near-falls
if ~isempty(dur_rec)
    mean_rec = mean(dur_rec);
    median_rec = median(dur_rec);
    Q1_rec = prctile(dur_rec,25);
    Q3_rec = prctile(dur_rec,75);

    figure
    histogram(dur_rec,20,'FaceColor',[0.4 0.4 0.4],'EdgeColor','none')
    hold on
    xline(mean_rec,'r','LineWidth',2,'DisplayName','Mean')
    xline(median_rec,'b','LineWidth',2,'DisplayName','Median')
    xline(Q1_rec,'k--','LineWidth',2,'DisplayName','Q1')
    xline(Q3_rec,'k--','LineWidth',2,'DisplayName','Q3')
    xlabel('Near-fall Duration (s)')
    ylabel('Number of Events')
    title('Distribution of Usable Near-fall Durations (Recovery)')
    legend('Near-fall durations','Mean','Median','Q1','Q3','Location','best')
    grid on
    hold off
end

%% 8) Histogram - near-falls that transition to fall
if ~isempty(dur_fall)
    mean_fall = mean(dur_fall);
    median_fall = median(dur_fall);
    Q1_fall = prctile(dur_fall,25);
    Q3_fall = prctile(dur_fall,75);

    figure
    histogram(dur_fall,20,'FaceColor',[0.4 0.4 0.4],'EdgeColor','none')
    hold on
    xline(mean_fall,'r','LineWidth',2,'DisplayName','Mean')
    xline(median_fall,'b','LineWidth',2,'DisplayName','Median')
    xline(Q1_fall,'k--','LineWidth',2,'DisplayName','Q1')
    xline(Q3_fall,'k--','LineWidth',2,'DisplayName','Q3')
    xlabel('Near-fall Duration (s)')
    ylabel('Number of Events')
    title('Distribution of Usable Near-fall Durations (Transition to Fall)')
    legend('Near-fall durations','Mean','Median','Q1','Q3','Location','best')
    grid on
    hold off
end






%% ============================================================
%% SECTION C - ML MODEL WITH FIXED LABEL-TO-RAW TRIAL MATCHING
%% ============================================================

% This section builds ML samples from:
% 0 = ADL
% 1 = NearFall
% 2 = Fall
%
% Consistency rule:
% - Random Forest and SVM use the SAME extracted samples
% - SAME participant split
% - SAME balanced training set
% - SAME held-out test set

% ---- MANUAL PARTICIPANT SPLIT ----
testParticipants = ["P1960","P2070","P2995"];
allParticipants = string(fieldnames(raw_filt));
trainParticipants = setdiff(allParticipants, testParticipants);

%% C1) Build feature matrix using LABEL TRIALS as master list
X = [];
Y = [];
sampleParticipant = strings(0,1);
sampleTrial = strings(0,1);

participants = fieldnames(labels);

for p = 1:numel(participants)

    pID = participants{p};

    if ~isfield(raw_filt, pID)
        continue;
    end

    labelTrials = fieldnames(labels.(pID));

    fprintf("\nBuilding ML samples for participant %s (%d/%d)\n", pID, p, numel(participants));

    for tt = 1:numel(labelTrials)

        trLabel = labelTrials{tt};

        rawTrialField = resolveRawTrialField(raw_filt.(pID), trLabel);

        if strlength(rawTrialField) == 0
            fprintf("  No raw trial match found for %s %s\n", pID, trLabel);
            continue;
        end

        if ~isfield(raw_filt.(pID).(rawTrialField), 'Back')
            continue;
        end

        M = raw_filt.(pID).(rawTrialField).Back;
        if size(M,1) < minSamplesPerSegment
            continue;
        end

        t = M(:,1);
        if isempty(t)
            continue;
        end

        nearFallsFull = eventStruct.(pID).(trLabel).NearFall;
        fallsFull     = eventStruct.(pID).(trLabel).Fall;

        % Keep only usable events
        nearFalls = filterUsableIntervals(nearFallsFull, t, minSamplesPerSegment);
        falls     = filterUsableIntervals(fallsFull, t, minSamplesPerSegment);

        fprintf("  %s -> %s | NF=%d Fall=%d\n", trLabel, rawTrialField, size(nearFalls,1), size(falls,1));

        %% ---- TRUE NEAR-FALL SEGMENTS ----
        for i = 1:size(nearFalls,1)
            t0 = nearFalls(i,1);
            t1 = nearFalls(i,2);

            idx = t >= t0 & t <= t1;
            if sum(idx) < minSamplesPerSegment
                continue;
            end

            W = M(idx,:);
            feat = extractSegmentFeatures(W);

            X(end+1,:) = feat;
            Y(end+1,1) = 1;
            sampleParticipant(end+1,1) = string(pID);
            sampleTrial(end+1,1) = string(trLabel);
        end

        %% ---- TRUE FALL SEGMENTS ----
        for i = 1:size(falls,1)
            t0 = falls(i,1);
            t1 = falls(i,2);

            idx = t >= t0 & t <= t1;
            if sum(idx) < minSamplesPerSegment
                continue;
            end

            W = M(idx,:);
            feat = extractSegmentFeatures(W);

            X(end+1,:) = feat;
            Y(end+1,1) = 2;
            sampleParticipant(end+1,1) = string(pID);
            sampleTrial(end+1,1) = string(trLabel);
        end

        %% ---- CLEAN ADL WINDOWS ----
        allEvents = [];

        if ~isempty(nearFalls)
            allEvents = [allEvents; nearFalls(:,1:2)];
        end

        if ~isempty(falls)
            allEvents = [allEvents; falls(:,1:2)];
        end

        tStartAll = t(1);
        tEndAll   = t(end);
        winStarts = tStartAll:adlStep_s:(tEndAll - adlWindow_s);

        for w = 1:numel(winStarts)
            w0 = winStarts(w);
            w1 = w0 + adlWindow_s;

            if overlapsBuffered(w0, w1, allEvents, eventBuffer_s)
                continue;
            end

            idx = t >= w0 & t < w1;
            if sum(idx) < minSamplesPerSegment
                continue;
            end

            W = M(idx,:);
            feat = extractSegmentFeatures(W);

            X(end+1,:) = feat;
            Y(end+1,1) = 0;
            sampleParticipant(end+1,1) = string(pID);
            sampleTrial(end+1,1) = string(trLabel);
        end
    end
end

featNames = getSegmentFeatureNames();
Ycat = categorical(Y, [0 1 2], {'ADL','NearFall','Fall'});

fprintf("\nOverall class counts:\n");
disp(countcats(Ycat))
disp(categories(Ycat))

%% C2) Print counts by participant
fprintf('\nCounts by participant:\n');
uP = unique(sampleParticipant);
for i = 1:numel(uP)
    idx = sampleParticipant == uP(i);
    Yi = Ycat(idx);
    fprintf('%s  ADL=%d  NF=%d  Fall=%d\n', uP(i), ...
        sum(Yi=='ADL'), sum(Yi=='NearFall'), sum(Yi=='Fall'));
end

%% C3) Split using manual participant split
isTrain = ismember(sampleParticipant, trainParticipants);
isTest  = ismember(sampleParticipant, testParticipants);

XTrain = X(isTrain,:);
YTrain = Ycat(isTrain);

XTest = X(isTest,:);
YTest = Ycat(isTest);

fprintf("\nTrain participants:\n");
disp(trainParticipants')

fprintf("Test participants:\n");
disp(testParticipants')

fprintf("Training samples: %d\n", size(XTrain,1));
fprintf("Testing samples: %d\n", size(XTest,1));

fprintf('\nTraining class counts:\n');
disp(countcats(YTrain))
disp(categories(YTrain))

fprintf('\nTesting class counts:\n');
disp(countcats(YTest))
disp(categories(YTest))

%% C4) Balance training data
idxADL  = find(YTrain == 'ADL');
idxNF   = find(YTrain == 'NearFall');
idxFall = find(YTrain == 'Fall');

targetPerClass = max([numel(idxNF), numel(idxFall), 1]);

rng(1)

if ~isempty(idxADL)
    idxADL_keep = idxADL(randperm(numel(idxADL), min(numel(idxADL), targetPerClass)));
else
    idxADL_keep = [];
end

if ~isempty(idxNF)
    idxNF_keep = idxNF(randperm(numel(idxNF), min(numel(idxNF), targetPerClass)));
else
    idxNF_keep = [];
end

if ~isempty(idxFall)
    idxFall_keep = idxFall(randperm(numel(idxFall), min(numel(idxFall), targetPerClass)));
else
    idxFall_keep = [];
end

idxKeep = [idxADL_keep; idxNF_keep; idxFall_keep];
idxKeep = idxKeep(randperm(numel(idxKeep)));

XTrain_bal = XTrain(idxKeep,:);
YTrain_bal = YTrain(idxKeep);

fprintf('\nBalanced training class counts:\n');
disp(countcats(YTrain_bal))
disp(categories(YTrain_bal))

%% C5) Train Random Forest
rfModel = TreeBagger(numTrees, XTrain_bal, YTrain_bal, ...
    'Method', 'classification', ...
    'OOBPrediction', 'On', ...
    'OOBPredictorImportance', 'On');

disp("Random forest trained.");

%% C6) Random Forest OOB training confusion matrix
predTrain_rf_oob = oobPredict(rfModel);
predTrain_rf_oob = categorical(predTrain_rf_oob, {'ADL','NearFall','Fall'});

mat_rf_oob = confusionmat(YTrain_bal, predTrain_rf_oob, ...
    'Order', categorical({'ADL','NearFall','Fall'}));

figure;
confusionchart(mat_rf_oob, {'ADL','NearFall','Fall'});
title("RANDOM FOREST OOB TRAINING")

disp("Random Forest OOB training confusion matrix rows=true, cols=predicted")
disp(array2table(mat_rf_oob, ...
    'VariableNames', {'Pred_ADL','Pred_NearFall','Pred_Fall'}, ...
    'RowNames', {'True_ADL','True_NearFall','True_Fall'}))

rfTrainAcc_oob = mean(predTrain_rf_oob == YTrain_bal);
fprintf("\nRandom Forest OOB training accuracy: %.3f\n", rfTrainAcc_oob);

%% C7) Random Forest TEST confusion matrix
predTest_rf = predict(rfModel, XTest);
predTest_rf = categorical(predTest_rf, {'ADL','NearFall','Fall'});

fprintf('\nRandom Forest predicted test class counts:\n');
disp(countcats(predTest_rf))
disp(categories(predTest_rf))

rfTestAcc = mean(predTest_rf == YTest);
fprintf("\nRandom Forest test accuracy: %.3f\n", rfTestAcc);

mat_rf_test = confusionmat(YTest, predTest_rf, ...
    'Order', categorical({'ADL','NearFall','Fall'}));

figure;
confusionchart(mat_rf_test, {'ADL','NearFall','Fall'});
title('RANDOM FOREST TEST CONFUSION MATRIX')

disp("Random Forest test confusion matrix rows=true, cols=predicted")
disp(array2table(mat_rf_test, ...
    'VariableNames', {'Pred_ADL','Pred_NearFall','Pred_Fall'}, ...
    'RowNames', {'True_ADL','True_NearFall','True_Fall'}))




%% C8) Random Forest feature importance
importance = rfModel.OOBPermutedPredictorDeltaError(:);
[importanceSorted, idxSort] = sort(importance, 'descend');

disp("Top Random Forest feature importances:")
topN = min(10, numel(idxSort));
for i = 1:topN
    fprintf("%2d. %-25s %.4f\n", i, featNames{idxSort(i)}, importanceSorted(i));
end

figure;
bar(importanceSorted(1:topN));
xticks(1:topN);
xticklabels(featNames(idxSort(1:topN)));
xtickangle(45);
ylabel('OOB Permuted Predictor Delta Error');
title('Top Random Forest Feature Importances');

%% ============================================================
%% SECTION D - SVM USING THE EXACT SAME DATA AS RANDOM FOREST
%% ============================================================

rng(1);

%% D1) Standardize using ONLY balanced training set statistics
mu_train = mean(XTrain_bal, 1);
sig_train = std(XTrain_bal, 0, 1);
sig_train(sig_train == 0) = 1;

XTrain_svm = (XTrain_bal - mu_train) ./ sig_train;
XTest_svm  = (XTest      - mu_train) ./ sig_train;

%% D2) Set up SVM learner
t_svm = templateSVM( ...
    'KernelFunction','linear', ...
    'KernelScale','auto', ...
    'Standardize',false);

%% D3) Train SVM on SAME balanced training data as RF
Mdl_svm = fitcecoc(XTrain_svm, YTrain_bal, ...
    'Learners', t_svm, ...
    'Prior', 'uniform');

disp("SVM trained.");

%% D4) SVM cross-validated TRAINING confusion matrix
svmCV = crossval(Mdl_svm, "KFold", 5);
predTrain_svm_cv = kfoldPredict(svmCV);

mat_svm_cv = confusionmat(YTrain_bal, predTrain_svm_cv, ...
    'Order', categorical({'ADL','NearFall','Fall'}));

figure;
confusionchart(mat_svm_cv, {'ADL','NearFall','Fall'});
title("SVM CROSS VALIDATION TRAINING")

disp("SVM cross-validated training confusion matrix rows=true, cols=predicted")
