function eventStruct = buildEventStruct(labels)
% Builds a shared eventStruct used by both Section B and Section C
%
% NearFall rows stored as [t0 t1 termLabel]
% where termLabel is 3 for recovered or 4 for fell
%
% Fall rows stored as [t0 t1]

    eventStruct = struct();
    participants_labels = fieldnames(labels);

    for p = 1:numel(participants_labels)

        pID = participants_labels{p};
        labelTrials = fieldnames(labels.(pID));

        for tt = 1:numel(labelTrials)

            trLabel = labelTrials{tt};
            T = labels.(pID).(trLabel);

            nearFalls = [];
            falls = [];

            if isempty(T) || size(T,2) < 2
                eventStruct.(pID).(trLabel).NearFall = nearFalls;
                eventStruct.(pID).(trLabel).Fall = falls;
                continue
            end

            eventLabel = T(:,1);
            time_s = T(:,2)/1000;

            % Near-fall = label 2 to first subsequent 3 or 4
            nfStartRows = find(eventLabel == 2);
            for i = 1:numel(nfStartRows)
                r0 = nfStartRows(i);
                t0 = time_s(r0);

                futureRows = find(time_s > t0);
                if isempty(futureRows)
                    continue
                end

                futureLabels = eventLabel(futureRows);
                idxEnd = find(futureLabels == 3 | futureLabels == 4, 1, 'first');
                if isempty(idxEnd)
                    continue
                end

                r1 = futureRows(idxEnd);
                t1 = time_s(r1);
                termLbl = eventLabel(r1);

                if t1 > t0
                    nearFalls(end+1,:) = [t0 t1 termLbl];
                end
            end

            % Fall = label 4 to first subsequent 5
            fallRows = find(eventLabel == 4);
            for i = 1:numel(fallRows)
                r0 = fallRows(i);
                t0 = time_s(r0);

                futureRows = find(time_s > t0);
                if isempty(futureRows)
                    continue
                end

                futureLabels = eventLabel(futureRows);
                idxEnd = find(futureLabels == 5, 1, 'first');
                if isempty(idxEnd)
                    continue
                end

                r1 = futureRows(idxEnd);
                t1 = time_s(r1);

                if t1 > t0
                    falls(end+1,:) = [t0 t1];
                end
            end

            eventStruct.(pID).(trLabel).NearFall = nearFalls;
            eventStruct.(pID).(trLabel).Fall = falls;
        end
    end
end

function intervalsOut = filterUsableIntervals(intervalsIn, t, minSamplesPerSegment)
% Keeps only intervals that have enough samples in the raw signal
% Preserves the number of columns even when empty

    if isempty(intervalsIn)
        intervalsOut = intervalsIn;
        return
    end

    intervalsOut = zeros(0, size(intervalsIn,2));

    for i = 1:size(intervalsIn,1)
        t0 = intervalsIn(i,1);
        t1 = intervalsIn(i,2);

        idx = t >= t0 & t <= t1;
        if sum(idx) >= minSamplesPerSegment
            intervalsOut(end+1,:) = intervalsIn(i,:);
        end
    end
end


function M_f = filterIMU_Matrix(M, fc_lowpass)
% M is Nx7: [t, ax, ay, az, wx, wy, wz]

    t = M(:,1);
    sig = M(:,2:7);

    Fs = estimateFs(t);

    if size(sig,1) < 10
        M_f = M;
        return
    end

    Wn = fc_lowpass/(Fs/2);
    Wn = min(max(Wn, 0.0001), 0.9999);

    [b,a] = butter(2, Wn, 'low');
    sig_f = filtfilt(b,a,sig);

    M_f = [t sig_f];
end

function M_f = filterECG_Matrix(M, f1, f2, use_notch, notch_f1, notch_f2)
% M is Nx2: [t, ecg]

    t = M(:,1);
    x = M(:,2);

    Fs = estimateFs(t);

    if numel(x) < 10
        M_f = M;
        return
    end

    Wn = [f1 f2]/(Fs/2);
    Wn(1) = max(Wn(1), 0.0001);
    Wn(2) = min(Wn(2), 0.9999);

    [bBP,aBP] = butter(2, Wn, 'bandpass');
    x_f = filtfilt(bBP,aBP,x);

    if use_notch
        WnN = [notch_f1 notch_f2]/(Fs/2);
        WnN(1) = max(WnN(1), 0.0001);
        WnN(2) = min(WnN(2), 0.9999);

        if WnN(2) > WnN(1)
            [bN,aN] = butter(2, WnN, 'stop');
            x_f = filtfilt(bN,aN,x_f);
        end
    end

    M_f = [t x_f];
end

function M_f = filterGSR_Matrix(M, fc_lowpass)
% M is Nx2: [t, gss]

    t = M(:,1);
    x = M(:,2);

    Fs = estimateFs(t);

    if numel(x) < 10
        M_f = M;
        return
    end

    Wn = fc_lowpass/(Fs/2);
    Wn = min(max(Wn, 0.0001), 0.9999);

    [b,a] = butter(2, Wn, 'low');
    x_f = filtfilt(b,a,x);

    M_f = [t x_f];
end

function Fs = estimateFs(t)
    dt = diff(t);
    dt = dt(isfinite(dt) & dt > 0);

    if isempty(dt)
        Fs = 1000;
    else
        Fs = 1/median(dt);
    end
end

function plotSensorsWindow_RawVsFilt(raw, raw_filt, labels, pID, trialBaseName, t0, t1, showMarkers, subtitleTxt)

    trialFields = string(fieldnames(raw.(pID)));

    if any(strcmp(trialFields, trialBaseName))
        trialField = trialBaseName;
    else
        hits = trialFields(contains(trialFields, trialBaseName, 'IgnoreCase', true));
        if isempty(hits)
            error("Trial '%s' not found in sensor data for %s.", trialBaseName, pID);
        end
        trialField = hits(end);
    end

    Xr = raw.(pID).(trialField);
    Xf = raw_filt.(pID).(trialField);

    timing_s = [];
    timingLabel = [];
    if showMarkers
        base = regexprep(trialBaseName, "_\d+$", "");
        if isfield(labels.(pID), base)
            T = labels.(pID).(base);
            timingLabel = T(:,1);
            timing_s = T(:,2)/1000;
        end
    end

    crop = @(M) M(M(:,1) >= t0 & M(:,1) <= t1, :);

    Br = crop(Xr.Back);  Lr = crop(Xr.Left_Thigh);  Rr = crop(Xr.Right_Thigh);
    Er = crop(Xr.ECG);   Gr = crop(Xr.GSS);

    Bf = crop(Xf.Back);  Lf = crop(Xf.Left_Thigh);  Rf = crop(Xf.Right_Thigh);
    Ef = crop(Xf.ECG);   Gf = crop(Xf.GSS);

    aBr = vecnorm(Br(:,2:4),2,2); wBr = vecnorm(Br(:,5:7),2,2);
    aLr = vecnorm(Lr(:,2:4),2,2); wLr = vecnorm(Lr(:,5:7),2,2);
    aRr = vecnorm(Rr(:,2:4),2,2); wRr = vecnorm(Rr(:,5:7),2,2);

    aBf = vecnorm(Bf(:,2:4),2,2); wBf = vecnorm(Bf(:,5:7),2,2);
    aLf = vecnorm(Lf(:,2:4),2,2); wLf = vecnorm(Lf(:,5:7),2,2);
    aRf = vecnorm(Rf(:,2:4),2,2); wRf = vecnorm(Rf(:,5:7),2,2);

    figure('Color','w');
    tl = tiledlayout(5,2,'TileSpacing','compact','Padding','compact');
    title(tl, pID + " | " + trialField + " | " + subtitleTxt + sprintf(" (%.1f-%.1fs)", t0, t1));

    ax11 = nexttile;
    h1 = plot(Br(:,1), aBr); hold on;
    h2 = plot(Br(:,1), wBr);
    ylabel("Back |a| (m/s^2), |w| (deg/s)");
    title("RAW");
    addLines(timing_s, timingLabel, t0, t1);

    ax12 = nexttile;
    plot(Bf(:,1), aBf); hold on;
    plot(Bf(:,1), wBf);
    title("FILTERED");
    addLines(timing_s, timingLabel, t0, t1);

    lg = legend(ax11, [h1 h2], "|a|", "|w|", "Location", "northoutside", "Orientation", "horizontal");
    lg.Box = "off";

    ax21 = nexttile;
    plot(Lr(:,1), aLr); hold on; plot(Lr(:,1), wLr);
    ylabel("L thigh |a|, |w|");
    addLines(timing_s, timingLabel, t0, t1);

    ax22 = nexttile;
    plot(Lf(:,1), aLf); hold on; plot(Lf(:,1), wLf);
    addLines(timing_s, timingLabel, t0, t1);

    ax31 = nexttile;
    plot(Rr(:,1), aRr); hold on; plot(Rr(:,1), wRr);
    ylabel("R thigh |a|, |w|");
    addLines(timing_s, timingLabel, t0, t1);

    ax32 = nexttile;
    plot(Rf(:,1), aRf); hold on; plot(Rf(:,1), wRf);
    addLines(timing_s, timingLabel, t0, t1);

    ax41 = nexttile;
    plot(Er(:,1), Er(:,2));
    ylabel("ECG (V)");
    addLines(timing_s, timingLabel, t0, t1);

    ax42 = nexttile;
    plot(Ef(:,1), Ef(:,2));
    addLines(timing_s, timingLabel, t0, t1);

    ax51 = nexttile;
    plot(Gr(:,1), Gr(:,2));
    ylabel("GSS / GSR (V)");
    xlabel("Time (s)");
    addLines(timing_s, timingLabel, t0, t1);

    ax52 = nexttile;
    plot(Gf(:,1), Gf(:,2));
    xlabel("Time (s)");
    addLines(timing_s, timingLabel, t0, t1);

    linkaxes([ax11 ax12 ax21 ax22 ax31 ax32 ax41 ax42 ax51 ax52], 'x');
end

function addLines(timing_s, timingLabel, t0, t1)
    if isempty(timing_s)
        return;
    end

    inWin = timing_s >= t0 & timing_s <= t1;
    ts = timing_s(inWin);
    ls = timingLabel(inWin);

    for i = 1:numel(ts)
        xline(ts(i), "--", "L" + ls(i), "LabelOrientation", "horizontal");
    end
end

function rawTrialField = resolveRawTrialField(rawParticipantStruct, labelTrialName)
% Find matching raw trial field for a label trial name

    rawTrialField = "";

    rawFields = string(fieldnames(rawParticipantStruct));

    if any(rawFields == labelTrialName)
        rawTrialField = labelTrialName;
        return;
    end

    hits = rawFields(contains(rawFields, labelTrialName, 'IgnoreCase', true));

    if ~isempty(hits)
        rawTrialField = hits(end);
        return;
    end
end

function tf = overlapsBuffered(w0, w1, intervals, buffer_s)
    tf = false;

    if isempty(intervals)
        return;
    end

    for i = 1:size(intervals,1)
        a = intervals(i,1) - buffer_s;
        b = intervals(i,2) + buffer_s;

        overlap = max(0, min(w1,b) - max(w0,a));
        if overlap > 0
            tf = true;
            return;
        end
    end
end

function feat = extractSegmentFeatures(W)
% W = [t ax ay az wx wy wz]

    ax = W(:,2);
    ay = W(:,3);
    az = W(:,4);
    wx = W(:,5);
    wy = W(:,6);
    wz = W(:,7);

    amag = vecnorm(W(:,2:4),2,2);
    wmag = vecnorm(W(:,5:7),2,2);

    feat = [ ...
        basic1DFeatures(ax), ...
        basic1DFeatures(ay), ...
        basic1DFeatures(az), ...
        basic1DFeatures(wx), ...
        basic1DFeatures(wy), ...
        basic1DFeatures(wz), ...
        basic1DFeatures(amag), ...
        basic1DFeatures(wmag) ...
        ];
end

function f = basic1DFeatures(x)
    f = [ ...
        mean(x), ...
        std(x), ...
        min(x), ...
        max(x), ...
        range(x), ...
        rms(x), ...
        sum(x.^2)/numel(x), ...
        median(x), ...
        iqr(x), ...
        mad(x,1) ...
        ];
end

function featNames = getSegmentFeatureNames()
    base = {'mean','std','min','max','range','rms','energy','median','iqr','mad'};
    signals = {'ax','ay','az','wx','wy','wz','amag','wmag'};

    featNames = cell(1, numel(base)*numel(signals));
    c = 1;
    for s = 1:numel(signals)
        for b = 1:numel(base)
            featNames{c} = [signals{s} '_' base{b}];
            c = c + 1;
        end
    end
end



function err = svmCVLoss(Xtr, Ytr, Xval, Yval)
% Helper loss function for sequentialfs using ECOC SVM

    t_local = templateSVM('KernelFunction','linear', ...
                          'KernelScale','auto', ...
                          'Standardize',false);

    mdl_local = fitcecoc(Xtr, Ytr, ...
        'Learners', t_local, ...
        'Prior', 'uniform');

    pred_local = predict(mdl_local, Xval);
    err = mean(pred_local ~= Yval);
end
