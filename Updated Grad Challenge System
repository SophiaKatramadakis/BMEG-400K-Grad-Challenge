%% ===== Grand Challenge Full Training + Test Prediction Script =====
% Training data:
%   GrandChallengeData.mat
%
% Test data:
%   GrandChallengeTestData.mat
%
% Outputs:
%   - Random Forest OOB training confusion matrix
%   - SVM cross-validated training confusion matrix
%   - RF and SVM predictions for the unlabeled test data
%   - RF and SVM submission tables per participant / trial
%
% Notes:
%   - Back is used as the main torso sensor when available
%   - Sternum is used when Back is not available
%   - Left_Thigh/Right_Thigh are preferred for limb sensors
%   - Left_Arm/Right_Arm are used if thigh sensors are not available
%   - ECG and GSS are also included in the feature vector

clear; clc; close all;

%% ============================================================
%% 1) USER PATHS
%% ============================================================

trainFilePath = "/Users/sophiakatramadakis/Documents/MATLAB/GrandChallengeData.mat";    % <-- update if needed
testFilePath  = "/Applications/MATLAB/GrandChallengeTestData.mat";                      % <-- update if needed

%% ============================================================
%% 2) LOAD TRAINING DATA
%% ============================================================

if ~isfile(trainFilePath)
    error("Could not find GrandChallengeData.mat at: %s", trainFilePath);
end

S_train = load(trainFilePath);

disp("Top-level variables in TRAINING MAT file:");
disp(fieldnames(S_train))

if ~isfield(S_train, "clean_labels")
    error("Expected S_train.clean_labels but it was not found.");
end
labels_train = S_train.clean_labels;

%% ============================================================
%% 3) LOAD TEST DATA
%% ============================================================

if ~isfile(testFilePath)
    error("Could not find GrandChallengeTestData.mat at: %s", testFilePath);
end

S_test = load(testFilePath);

disp("Top-level variables in TEST MAT file:");
disp(fieldnames(S_test))

if ~isfield(S_test, "test_data")
    error("Expected GrandChallengeTestData.mat to contain a variable named test_data.");
end

test_data = S_test.test_data;

disp("Test participants:");
disp(fieldnames(test_data))

%% ============================================================
%% 4) AUTO-FIND RAW TRAINING SENSOR STRUCT
%% ============================================================

raw_train = autoFindRawSensorStruct(S_train, labels_train);

disp("Training participants found:");
disp(fieldnames(raw_train))

%% ============================================================
%% 5) FILTER SETTINGS
%% ============================================================

IMU.lowpass_fc = 20;      % Hz

ECG.bandpass_f1 = 0.5;    % Hz
ECG.bandpass_f2 = 150;    % Hz
ECG.use_notch   = true;
ECG.notch_f1    = 50;     % Hz
ECG.notch_f2    = 70;     % Hz

GSR.lowpass_fc = 1;       % Hz

rng(1);

adlWindow_s = 1.0;
adlStep_s   = 1.0;
eventBuffer_s = 0.25;
numTrees = 200;
minSamplesPerSegment = 20;
kfolds = 5;

%% ============================================================
%% SECTION A - FILTER TRAINING DATA
%% ============================================================

raw_train_filt = raw_train;
participants_train = string(fieldnames(raw_train));

for p = 1:numel(participants_train)
    pID = participants_train(p);
    trialNames = string(fieldnames(raw_train.(pID)));

    for tt = 1:numel(trialNames)
        tr = trialNames(tt);
        X = raw_train.(pID).(tr);

        if isfield(X,"Back")
            raw_train_filt.(pID).(tr).Back = filterIMU_Matrix(X.Back, IMU.lowpass_fc);
        end

        if isfield(X,"Left_Thigh")
            raw_train_filt.(pID).(tr).Left_Thigh = filterIMU_Matrix(X.Left_Thigh, IMU.lowpass_fc);
        end

        if isfield(X,"Right_Thigh")
            raw_train_filt.(pID).(tr).Right_Thigh = filterIMU_Matrix(X.Right_Thigh, IMU.lowpass_fc);
        end

        if isfield(X,"ECG")
            raw_train_filt.(pID).(tr).ECG = filterECG_Matrix(X.ECG, ECG.bandpass_f1, ECG.bandpass_f2, ...
                ECG.use_notch, ECG.notch_f1, ECG.notch_f2);
        end

        if isfield(X,"GSS")
            raw_train_filt.(pID).(tr).GSS = filterGSR_Matrix(X.GSS, GSR.lowpass_fc);
        end
    end
end

disp("Filtering complete for TRAINING data.");

%% ============================================================
%% SECTION B - FILTER TEST DATA
%% ============================================================

test_data_filt = test_data;
participants_test = string(fieldnames(test_data));

for p = 1:numel(participants_test)
    pID = participants_test(p);
    trialNames = string(fieldnames(test_data.(pID)));

    for tt = 1:numel(trialNames)
        tr = trialNames(tt);
        X = test_data.(pID).(tr);

        if isfield(X,"Back")
            test_data_filt.(pID).(tr).Back = filterIMU_Matrix(X.Back, IMU.lowpass_fc);
        end

        if isfield(X,"Sternum")
            test_data_filt.(pID).(tr).Sternum = filterIMU_Matrix(X.Sternum, IMU.lowpass_fc);
        end

        if isfield(X,"Left_Thigh")
            test_data_filt.(pID).(tr).Left_Thigh = filterIMU_Matrix(X.Left_Thigh, IMU.lowpass_fc);
        end

        if isfield(X,"Right_Thigh")
            test_data_filt.(pID).(tr).Right_Thigh = filterIMU_Matrix(X.Right_Thigh, IMU.lowpass_fc);
        end

        if isfield(X,"Left_Arm")
            test_data_filt.(pID).(tr).Left_Arm = filterIMU_Matrix(X.Left_Arm, IMU.lowpass_fc);
        end

        if isfield(X,"Right_Arm")
            test_data_filt.(pID).(tr).Right_Arm = filterIMU_Matrix(X.Right_Arm, IMU.lowpass_fc);
        end

        if isfield(X,"ECG")
            test_data_filt.(pID).(tr).ECG = filterECG_Matrix(X.ECG, ECG.bandpass_f1, ECG.bandpass_f2, ...
                ECG.use_notch, ECG.notch_f1, ECG.notch_f2);
        end

        if isfield(X,"GSS")
            test_data_filt.(pID).(tr).GSS = filterGSR_Matrix(X.GSS, GSR.lowpass_fc);
        end
    end
end

disp("Filtering complete for TEST data.");

%% ============================================================
%% SECTION C - BUILD EVENT STRUCT FROM TRAINING LABELS
%% ============================================================

eventStruct_train = buildEventStruct(labels_train);
disp("Event intervals built from TRAINING labels.");

%% ============================================================
%% SECTION D - BUILD TRAINING FEATURE MATRIX
%% ============================================================

[XTrain, YTrain, trainParticipant, trainTrial] = buildFeatureMatrixFromLabeledSet( ...
    raw_train_filt, labels_train, eventStruct_train, adlWindow_s, adlStep_s, eventBuffer_s, minSamplesPerSegment);

featNames = getMultiSensorFeatureNames();
YTrain_cat = categorical(YTrain, [0 1 2], {'ADL','NearFall','Fall'});

fprintf("\nOverall TRAINING class counts:\n");
disp(countcats(YTrain_cat))
disp(categories(YTrain_cat))

%% Balance training data
idxADL  = find(YTrain_cat == 'ADL');
idxNF   = find(YTrain_cat == 'NearFall');
idxFall = find(YTrain_cat == 'Fall');

targetPerClass = max([numel(idxNF), numel(idxFall), 1]);

rng(1)

if ~isempty(idxADL)
    idxADL_keep = idxADL(randperm(numel(idxADL), min(numel(idxADL), targetPerClass)));
else
    idxADL_keep = [];
end

if ~isempty(idxNF)
    idxNF_keep = idxNF(randperm(numel(idxNF), min(numel(idxNF), targetPerClass)));
else
    idxNF_keep = [];
end

if ~isempty(idxFall)
    idxFall_keep = idxFall(randperm(numel(idxFall), min(numel(idxFall), targetPerClass)));
else
    idxFall_keep = [];
end

idxKeep = [idxADL_keep; idxNF_keep; idxFall_keep];
idxKeep = idxKeep(randperm(numel(idxKeep)));

XTrain_bal = XTrain(idxKeep,:);
YTrain_bal = YTrain_cat(idxKeep);

fprintf('\nBalanced training class counts:\n');
disp(countcats(YTrain_bal))
disp(categories(YTrain_bal))

%% ============================================================
%% SECTION E - BUILD TEST FEATURE MATRIX
%% ============================================================

XTest = [];
testParticipant = strings(0,1);
testTrial = strings(0,1);
testWinStart = [];
testWinEnd = [];

participants_test = fieldnames(test_data_filt);

for p = 1:numel(participants_test)

    pID = participants_test{p};
    trialNames = fieldnames(test_data_filt.(pID));

    fprintf("\nBuilding TEST windows for participant %s (%d/%d)\n", pID, p, numel(participants_test));

    for tt = 1:numel(trialNames)

        tr = trialNames{tt};

        sensorMap = getSensorMap(test_data_filt.(pID).(tr));
        if ~sensorMap.hasAny
            fprintf("  No usable sensors found for %s %s\n", pID, tr);
            continue;
        end

        % choose a reference time vector from the core sensor if possible
        refField = sensorMap.core;
        if strlength(refField) == 0
            refField = sensorMap.limb1;
        end
        if strlength(refField) == 0
            refField = sensorMap.limb2;
        end
        if strlength(refField) == 0
            fprintf("  No usable IMU reference field found for %s %s\n", pID, tr);
            continue;
        end

        Mref = test_data_filt.(pID).(tr).(refField);
        if size(Mref,1) < minSamplesPerSegment
            continue;
        end

        t = Mref(:,1);
        if isempty(t)
            continue;
        end

        tStartAll = t(1);
        tEndAll   = t(end);
        winStarts = tStartAll:adlStep_s:(tEndAll - adlWindow_s);

        fprintf("  %s | windows=%d\n", tr, numel(winStarts));

        for w = 1:numel(winStarts)
            w0 = winStarts(w);
            w1 = w0 + adlWindow_s;

            feat = extractMultiSensorWindowFeatures(test_data_filt.(pID).(tr), sensorMap, w0, w1, minSamplesPerSegment);

            if isempty(feat)
                continue;
            end

            XTest(end+1,:) = feat;
            testParticipant(end+1,1) = string(pID);
            testTrial(end+1,1) = string(tr);
            testWinStart(end+1,1) = w0;
            testWinEnd(end+1,1) = w1;
        end
    end
end

fprintf("\nTotal TEST windows created from unlabeled test data: %d\n", size(XTest,1));

%% ============================================================
%% SECTION F - RANDOM FOREST
%% ============================================================

rfModel = TreeBagger(numTrees, XTrain_bal, YTrain_bal, ...
    'Method', 'classification', ...
    'OOBPrediction', 'On', ...
    'OOBPredictorImportance', 'On');

disp("Random Forest trained.");

%% F1) Random Forest OOB training confusion matrix
predTrain_rf_oob = oobPredict(rfModel);
predTrain_rf_oob = categorical(predTrain_rf_oob, {'ADL','NearFall','Fall'});

mat_rf_oob = confusionmat(YTrain_bal, predTrain_rf_oob, ...
    'Order', categorical({'ADL','NearFall','Fall'}));

figure;
confusionchart(mat_rf_oob, {'ADL','NearFall','Fall'});
title("RANDOM FOREST OOB TRAINING")

disp("Random Forest OOB training confusion matrix rows=true, cols=predicted")
disp(array2table(mat_rf_oob, ...
    'VariableNames', {'Pred_ADL','Pred_NearFall','Pred_Fall'}, ...
    'RowNames', {'True_ADL','True_NearFall','True_Fall'}))

rfTrainAcc_oob = mean(predTrain_rf_oob == YTrain_bal);
fprintf("\nRandom Forest OOB training accuracy: %.3f\n", rfTrainAcc_oob);

%% F2) Random Forest predictions on test data
predTest_rf = predict(rfModel, XTest);
predTest_rf = categorical(predTest_rf, {'ADL','NearFall','Fall'});

fprintf('\nRandom Forest predicted TEST class counts:\n');
disp(countcats(predTest_rf))
disp(categories(predTest_rf))

rfTestResults = table(testParticipant, testTrial, testWinStart, testWinEnd, predTest_rf, ...
    'VariableNames', {'Participant','Trial','WindowStart_s','WindowEnd_s','PredictedLabel'});

rfLabelNum = nan(height(rfTestResults),1);
rfLabelNum(rfTestResults.PredictedLabel == 'ADL') = 0;
rfLabelNum(rfTestResults.PredictedLabel == 'NearFall') = 1;
rfLabelNum(rfTestResults.PredictedLabel == 'Fall') = 2;
rfTestResults.PredictedLabelNum = rfLabelNum;

disp("Random Forest test predictions table created: rfTestResults");

%% F3) Random Forest feature importance
importance = rfModel.OOBPermutedPredictorDeltaError(:);
[importanceSorted, idxSort] = sort(importance, 'descend');

disp("Top Random Forest feature importances:")
topN = min(15, numel(idxSort));
for i = 1:topN
    fprintf("%2d. %-35s %.4f\n", i, featNames{idxSort(i)}, importanceSorted(i));
end

figure;
bar(importanceSorted(1:topN));
xticks(1:topN);
xticklabels(featNames(idxSort(1:topN)));
xtickangle(45);
ylabel('OOB Permuted Predictor Delta Error');
title('Top Random Forest Feature Importances');

%% ============================================================
%% RANDOM FOREST EVENT TABLES FOR SUBMISSION
%% ============================================================

rfSubmissionTables = buildSubmissionTables(rfTestResults);

disp("Random Forest submission tables created:")
disp(fieldnames(rfSubmissionTables))

rfParticipants = fieldnames(rfSubmissionTables);
for p = 1:numel(rfParticipants)
    pID = rfParticipants{p};
    rfTrials = fieldnames(rfSubmissionTables.(pID));

    for t = 1:numel(rfTrials)
        tr = rfTrials{t};
        Tsub = rfSubmissionTables.(pID).(tr);

        outName = sprintf("RF_%s_%s.csv", pID, tr);
        writematrix(Tsub, outName);
    end
end

%% ============================================================
%% SECTION G - SVM
%% ============================================================

mu_train = mean(XTrain_bal, 1);
sig_train = std(XTrain_bal, 0, 1);
sig_train(sig_train == 0) = 1;

XTrain_svm = (XTrain_bal - mu_train) ./ sig_train;
XTest_svm  = (XTest      - mu_train) ./ sig_train;

t_svm = templateSVM( ...
    'KernelFunction','linear', ...
    'KernelScale','auto', ...
    'Standardize',false);

Mdl_svm = fitcecoc(XTrain_svm, YTrain_bal, ...
    'Learners', t_svm, ...
    'Prior', 'uniform');

disp("SVM trained.");

%% G1) SVM cross-validated training confusion matrix
svmCV = crossval(Mdl_svm, "KFold", kfolds);
predTrain_svm_cv = kfoldPredict(svmCV);

mat_svm_cv = confusionmat(YTrain_bal, predTrain_svm_cv, ...
    'Order', categorical({'ADL','NearFall','Fall'}));

figure;
confusionchart(mat_svm_cv, {'ADL','NearFall','Fall'});
title("SVM CROSS VALIDATION TRAINING")

disp("SVM cross-validated training confusion matrix rows=true, cols=predicted")
disp(array2table(mat_svm_cv, ...
    'VariableNames', {'Pred_ADL','Pred_NearFall','Pred_Fall'}, ...
    'RowNames', {'True_ADL','True_NearFall','True_Fall'}))

svmTrainAcc_cv = mean(predTrain_svm_cv == YTrain_bal);
fprintf("\nSVM cross-validated training accuracy: %.3f\n", svmTrainAcc_cv);

%% G2) SVM predictions on test data
predTest_svm = predict(Mdl_svm, XTest_svm);

fprintf("\nSVM predicted TEST class counts:\n");
disp(countcats(predTest_svm))
disp(categories(predTest_svm))

svmTestResults = table(testParticipant, testTrial, testWinStart, testWinEnd, predTest_svm, ...
    'VariableNames', {'Participant','Trial','WindowStart_s','WindowEnd_s','PredictedLabel'});

svmLabelNum = nan(height(svmTestResults),1);
svmLabelNum(svmTestResults.PredictedLabel == 'ADL') = 0;
svmLabelNum(svmTestResults.PredictedLabel == 'NearFall') = 1;
svmLabelNum(svmTestResults.PredictedLabel == 'Fall') = 2;
svmTestResults.PredictedLabelNum = svmLabelNum;

disp("SVM test predictions table created: svmTestResults");

%% ============================================================
%% SVM EVENT TABLES FOR SUBMISSION
%% ============================================================

svmSubmissionTables = buildSubmissionTables(svmTestResults);

disp("SVM submission tables created:")
disp(fieldnames(svmSubmissionTables))

svmParticipants = fieldnames(svmSubmissionTables);
for p = 1:numel(svmParticipants)
    pID = svmParticipants{p};
    svmTrials = fieldnames(svmSubmissionTables.(pID));

    for t = 1:numel(svmTrials)
        tr = svmTrials{t};
        Tsub = svmSubmissionTables.(pID).(tr);

        outName = sprintf("SVM_%s_%s.csv", pID, tr);
        writematrix(Tsub, outName);
    end
end

