% --- Define time-domain features for ECG and GSS ---
% ECG
%   Peak-to-peak amplitude = max(x) - min(x)
%   Variance = var(x)
% GSS
%   Range (peak-to-peak) = max(x) - min(x)
%   Slope over segment = (x_end - x_start) / duration

results_ECG = struct();
results_GSS = struct();

for i = 1:numel(situations)
    tag = situations(i);

    % ----- ECG -----
    ecg = SIT.(tag).ECG.x;
    results_ECG.(tag).PtP = max(ecg) - min(ecg);
    results_ECG.(tag).Var = var(ecg);

    % ----- GSS -----
    gss = SIT.(tag).GSS.x;
    t   = SIT.(tag).GSS.t;
    results_GSS.(tag).Range = max(gss) - min(gss);

    dur = t(end) - t(1);
    if dur > 0
        results_GSS.(tag).Slope = (gss(end) - gss(1)) / dur; % units per second
    else
        results_GSS.(tag).Slope = NaN;
    end
end

