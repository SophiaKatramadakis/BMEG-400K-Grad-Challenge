%% ================== Local Functions ==================

function trialField = resolveTrialField(rawStruct, pID, trialBase)
    tf = string(fieldnames(rawStruct.(pID)));
    if any(strcmp(tf, trialBase))
        trialField = trialBase;
    else
        hits = tf(contains(tf, trialBase, 'IgnoreCase', true));
        if isempty(hits)
            error("Trial '%s' not found for %s.", trialBase, pID);
        end
        trialField = hits(end);
    end
end

function [t0, t1] = getNearFallWindow(labels, pID, trialBase, pad_s)
    if ~(isfield(labels,pID) && isfield(labels.(pID),trialBase))
        error("No labels found for %s %s.", pID, trialBase);
    end
    T = labels.(pID).(trialBase); % [label,time_ms,group]
    idx = find(T(:,3)==1);
    if numel(idx)<3, error("No near-fall block found for %s %s.", pID, trialBase); end
    blk = T(idx(1:3),:);
    t0 = blk(1,2)/1000;
    t1 = blk(3,2)/1000 + pad_s;
end

function [t0, t1] = getFallWindow(labels, pID, trialBase, pad_s)
    if ~(isfield(labels,pID) && isfield(labels.(pID),trialBase))
        error("No labels found for %s %s.", pID, trialBase);
    end
    T = labels.(pID).(trialBase); % [label,time_ms,group]
    idx = find(T(:,3)==4);
    if numel(idx)<4, error("No fall block found for %s %s.", pID, trialBase); end
    blk = T(idx(1:4),:);
    t0 = blk(3,2)/1000;          % L4
    t1 = blk(4,2)/1000 + pad_s;  % L5 + padding
end

function out = makeSegments(X, t0, t1)
% Extract Back IMU |w|, ECG, GSS for a window
    out = struct();
    out.IMU = getIMU_Mag(X.Back, t0, t1, "w"); % Back |w|
    out.ECG = get1D(X.ECG, t0, t1);
    out.GSS = get1D(X.GSS, t0, t1);
end

function out = getIMU_Mag(M, t0, t1, whichMag)
% M Nx7 [t ax ay az wx wy wz]
    crop = M(M(:,1)>=t0 & M(:,1)<=t1,:);
    t = crop(:,1);
    Fs = estimateFs(t);
    if whichMag=="a"
        x = vecnorm(crop(:,2:4),2,2);
    else
        x = vecnorm(crop(:,5:7),2,2);
    end
    out.t = t; out.x = x; out.Fs = Fs;
end

function out = get1D(M, t0, t1)
% M Nx2 [t x]
    crop = M(M(:,1)>=t0 & M(:,1)<=t1,:);
    out.t = crop(:,1);
    out.x = crop(:,2);
    out.Fs = estimateFs(out.t);
end

function plot4Situations_Time(SIT, sensorName, ylab, figTitleTxt)
    situations = ["Walk","Stand","NearFall","Fall"];
    figure('Color','w'); clf;
    tiledlayout(4,1,'TileSpacing','compact','Padding','compact');

    for i = 1:numel(situations)
        tag = situations(i);
        s = SIT.(tag).(sensorName);
        nexttile;
        plot(s.t, s.x);
        title(tag);
        ylabel(ylab);
        xlabel("Time (s)");
    end
    sgtitle(figTitleTxt);
end

function plot4Situations_FFT(SIT, sensorName, figTitleTxt, fmin, fmax)
% Single-sided FFT magnitude (windowed, demeaned)
    situations = ["Walk","Stand","NearFall","Fall"];
    figure('Color','w'); clf;
    tiledlayout(4,1,'TileSpacing','compact','Padding','compact');

    for i = 1:numel(situations)
        tag = situations(i);
        s = SIT.(tag).(sensorName);

        [f, mag] = oneSidedFFTmag(s.x, s.Fs);

        nexttile;
        plot(f, mag);
        xlim([fmin fmax]);
        title(tag);
        xlabel("Frequency (Hz)");
        ylabel("Magnitude");
    end
    sgtitle(figTitleTxt);
end

function [f, mag1] = oneSidedFFTmag(x, Fs)
% Demean + Hann window; return single-sided magnitude
    x = x(:);
    x = x - mean(x);

    N = numel(x);
    if N < 8
        f = 0; mag1 = 0;
        return
    end

    w = hann(N);
    xw = x .* w;

    Y = fft(xw);
    P2 = abs(Y/N);

    nHalf = floor(N/2) + 1;
    mag1 = P2(1:nHalf);
    mag1(2:end-1) = 2*mag1(2:end-1);

    f = Fs*(0:(nHalf-1))/N;
end

function Fs = estimateFs(t)
    dt = diff(t);
    dt = dt(isfinite(dt) & dt>0);
    if isempty(dt), Fs = 1000; else Fs = 1/median(dt); end
end

function M_f = filterIMU_Matrix(M, fc_lowpass)
% 4th-order lagless Butterworth low-pass
    t = M(:,1);
    sig = M(:,2:7);
    Fs = estimateFs(t);
    Wn = min(max(fc_lowpass/(Fs/2), 0.0001), 0.9999);
    [b,a] = butter(2, Wn, 'low');
    sig_f = filtfilt(b,a,sig);
    M_f = [t sig_f];
end

function M_f = filterECG_Matrix(M, f1, f2, use_notch, nf1, nf2)
% 4th-order lagless Butterworth band-pass + optional notch
    t = M(:,1);
    x = M(:,2);
    Fs = estimateFs(t);

    Wn = [f1 f2]/(Fs/2);
    Wn(1) = max(Wn(1), 0.0001);
    Wn(2) = min(Wn(2), 0.9999);
    [bBP,aBP] = butter(2, Wn, 'bandpass');
    x_f = filtfilt(bBP,aBP,x);

    if use_notch
        WnN = [nf1 nf2]/(Fs/2);
        WnN(1) = max(WnN(1), 0.0001);
        WnN(2) = min(WnN(2), 0.9999);
        if WnN(2) > WnN(1)
            [bN,aN] = butter(2, WnN, 'stop');
            x_f = filtfilt(bN,aN,x_f);
        end
    end

    M_f = [t x_f];
end

function M_f = filterGSS_Matrix(M, fc_lowpass)
% 4th-order lagless Butterworth low-pass
    t = M(:,1);
    x = M(:,2);
    Fs = estimateFs(t);
    Wn = min(max(fc_lowpass/(Fs/2), 0.0001), 0.9999);
    [b,a] = butter(2, Wn, 'low');
    x_f = filtfilt(b,a,x);
    M_f = [t x_f];
end

function M_f = filterGSR_Matrix(M, fc_lowpass)
    M_f = filterGSS_Matrix(M, fc_lowpass);
end
