%% 6B) Dominant frequency (frequency with largest magnitude) within each segment
% Uses single-sided FFT magnitude of the segment signal:
%   f_dom = argmax_f |X(f)|
%
% NOTE: For real signals, the largest magnitude is often at/near 0 Hz (DC),
% especially for GSS. To make this meaningful, we exclude DC and optionally
% restrict to a plausible band for each sensor.

situations = ["Walk","Stand","NearFall","Fall"];
sensors = ["IMU","ECG","GSS"];

% Frequency bands to search (Hz). Adjust if you want.
% IMU: motion band
band.IMU = [0.5 10];
% ECG: heart-rate/morphology band (dominant peaks often ~1-3 Hz for HR)
band.ECG = [0.5 10];
% GSS: very slow, but exclude DC so drift doesn't dominate
band.GSS = [0.01 1];

domFreq = struct();

fprintf("\n===== Dominant frequency (max FFT magnitude) =====\n");
fprintf("Sensor\t\tSituation\tf_dom (Hz)\tMagnitude\n");

for s = 1:numel(sensors)
    sensorName = sensors(s);
    fSearch = band.(sensorName);

    for i = 1:numel(situations)
        tag = situations(i);

        segObj = SIT.(tag).(sensorName);

        % FFT magnitude
        [f, mag] = oneSidedFFTmag(segObj.x, segObj.Fs);

        % Exclude DC and limit to the band
        idx = (f >= fSearch(1)) & (f <= fSearch(2));
        if ~any(idx)
            domFreq.(sensorName).(tag).f = NaN;
            domFreq.(sensorName).(tag).mag = NaN;
            fprintf("%s\t\t%s\t\tNaN\t\tNaN\n", sensorName, tag);
            continue
        end

        [mmax, k] = max(mag(idx));
        ff = f(idx);
        fdom = ff(k);

        domFreq.(sensorName).(tag).f = fdom;
        domFreq.(sensorName).(tag).mag = mmax;

        fprintf("%s\t\t%s\t\t%.3f\t\t%.3g\n", sensorName, tag, fdom, mmax);
    end
end


