% P2070 only
% Time-domain analysis stays the same (Back IMU |w| features + time plots)
% Frequency-domain analysis: plot FFT magnitude for EACH sensor type
%   IMU (Back |w|), ECG, GSS
% and for EACH situation:
%   Walk ADL (0-20s), Stand ADL (0-60s), Slip Near-fall, Slip Fall
%
% Filtering included (Butterworth 4th-order lagless via butter(2)+filtfilt)

clear; clc;

%% 1) Load MAT file and auto-find raw struct + labels
filePath = "/Users/sophiakatramadakis/Documents/MATLAB/GrandChallengeData.mat"; % <-- update if needed
S = load(filePath);

if ~isfield(S,"clean_labels")
    error("Expected S.clean_labels but it wasn't found.");
end
labels = S.clean_labels;

names = fieldnames(S);
raw = [];
for k = 1:numel(names)
    nm = names{k};
    if strcmp(nm,"clean_labels"), continue; end
    if ~isstruct(S.(nm)), continue; end
    if ~isfield(S.(nm),"P1960"), continue; end
    tf = fieldnames(S.(nm).P1960);
    if isempty(tf), continue; end
    t1 = tf{1};
    if isstruct(S.(nm).P1960.(t1))
        sf = fieldnames(S.(nm).P1960.(t1));
        if any(strcmp(sf,"Back")) && any(strcmp(sf,"ECG")) && any(strcmp(sf,"GSS"))
            raw = S.(nm);
            fprintf("Using RAW sensor struct: S.%s\n", nm);
            break
        end
    end
end
if isempty(raw), error("Could not auto-find the raw sensor struct."); end

%% 2) Filter parameters
IMU_fc = 20;                    % Hz low-pass
ECG_f1 = 0.5; ECG_f2 = 40;      % Hz band-pass
ECG_useNotch = true;             % notch around mains for wider passband
ECG_notch_f1 = 50; ECG_notch_f2 = 70;
GSS_fc = 1;                      % Hz low-pass

%% 3) Filter ALL data (creates raw_filt)
raw_filt = raw;
participants = string(fieldnames(raw));

for p = 1:numel(participants)
    pID = participants(p);
    trialNames = string(fieldnames(raw.(pID)));

    for tt = 1:numel(trialNames)
        tr = trialNames(tt);
        X = raw.(pID).(tr);

        if isfield(X,"Back")
            raw_filt.(pID).(tr).Back = filterIMU_Matrix(X.Back, IMU_fc);
        end
        if isfield(X,"Left_Thigh")
            raw_filt.(pID).(tr).Left_Thigh = filterIMU_Matrix(X.Left_Thigh, IMU_fc);
        end
        if isfield(X,"Right_Thigh")
            raw_filt.(pID).(tr).Right_Thigh = filterIMU_Matrix(X.Right_Thigh, IMU_fc);
        end
        if isfield(X,"ECG")
            raw_filt.(pID).(tr).ECG = filterECG_Matrix(X.ECG, ECG_f1, ECG_f2, ECG_useNotch, ECG_notch_f1, ECG_notch_f2);
        end
        if isfield(X,"GSS")
            raw_filt.(pID).(tr).GSS = filterGSS_Matrix(X.GSS, GSS_fc);
        end
    end
end
disp("Filtering complete.");

%% 4) Define P2070 situations and extract segments (FILTERED)
